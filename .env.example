# Секрет сессий (обязательно смените на сервере)
SECRET_KEY=change-me-to-random-string

# База данных (на сервере файл остаётся на диске сервера)
DATABASE_URL=sqlite:///./data/zadachi.db

# Начальные пароли — используются ОДИН раз при первом запуске,
# когда создаются пользователи. Дальше пароли только в БД (хеши).
# После первого входа смените пароль в «Настройках».
PASS_NIKITA=change-me
PASS_ARTEM=change-me
PASS_ILYA=change-me

# Нейросеть для кнопки «Сгенерировать» название (необязательно)
# Рекомендуем DeepSeek — дёшево, при регистрации обычно дают бесплатные кредиты:
# 1) https://platform.deepseek.com → API Keys → Create
# 2) вставьте ключ сюда:
# DEEPSEEK_API_KEY=sk-...
# DEEPSEEK_MODEL=deepseek-chat

# Альтернатива — OpenAI:
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o-mini
