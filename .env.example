# Секрет сессий (обязательно смените на сервере)
SECRET_KEY=change-me-to-random-string

# База данных (на сервере файл остаётся на диске сервера)
DATABASE_URL=sqlite:///./data/zadachi.db

# Начальные пароли — используются ОДИН раз при первом запуске
PASS_NIKITA=change-me
PASS_ARTEM=change-me
PASS_ILYA=change-me

# === Нейросеть для «Сгенерировать» название ===
# 1) Полностью бесплатно локально — Ollama (рекомендуется):
#    brew install ollama && ollama serve
#    ollama pull qwen2.5:3b
# OLLAMA_BASE_URL=http://127.0.0.1:11434
# OLLAMA_MODEL=qwen2.5:3b

# 2) Бесплатный облачный ключ Google Gemini:
#    https://aistudio.google.com/apikey
# GEMINI_API_KEY=...

# 3) DeepSeek / OpenAI (по желанию)
# DEEPSEEK_API_KEY=sk-...
